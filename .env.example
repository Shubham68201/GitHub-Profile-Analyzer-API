# Server
PORT=5000
NODE_ENV=development

# MySQL Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=github_analyzer

# GitHub API
# Optional but recommended: generate a personal access token (no scopes needed for public data)
# at https://github.com/settings/tokens to raise the rate limit from 60/hr to 5000/hr
GITHUB_TOKEN=

# GitHub API base URL (rarely needs changing)
GITHUB_API_URL=https://api.github.com
